<script>
  // Nav active on scroll
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a');
  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(s => { if (window.scrollY >= s.offsetTop - 80) current = s.id; });
    navLinks.forEach(a => { a.classList.remove('active'); if (a.getAttribute('href') === '#' + current) a.classList.add('active'); });
  });
  // Notes switcher
  let currentClass = '6', currentSubj = 'math';
  function switchClass(cls) {
    currentClass = cls;
    document.querySelectorAll('.notes-tab').forEach((t,i) => t.classList.toggle('active', ['6','7','8','9','10','11','12'][i] === cls));
    updateNotesGrid();
  }
  function switchSubject(subj) {
    currentSubj = subj;
    document.getElementById('subj-math').classList.toggle('active', subj === 'math');
    document.getElementById('subj-sci').classList.toggle('active', subj === 'sci');
    updateNotesGrid();
  }
  function updateNotesGrid() {
    document.querySelectorAll('.notes-grid').forEach(g => g.classList.remove('active'));
    const t = document.getElementById('notes-' + currentClass + '-' + currentSubj);
    if (t) t.classList.add('active');
  }
  // Assignments switcher
  function switchAssign(type, el) {
    document.querySelectorAll('.assign-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.assign-list').forEach(l => l.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('assign-' + type).classList.add('active');
  }
  // NEP switcher
  function switchNep(lang, el) {
    document.querySelectorAll('.nep-lang-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.nep-content').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('nep-' + lang).classList.add('active');
  }
  // Star rating
  let selectedRating = 0;
  function setRating(n) {
    selectedRating = n;
    document.querySelectorAll('.star').forEach((s, i) => s.classList.toggle('selected', i < n));
  }
  // Feedback submit
  function submitFeedback() {
    const name = document.getElementById('fb-name').value.trim();
    const cls = document.getElementById('fb-class').value;
    const text = document.getElementById('fb-text').value.trim();
    if (!name || !cls || !text || selectedRating === 0) { alert('Please fill all fields and select a rating!'); return; }
    document.getElementById('fb-success').style.display = 'block';
    document.getElementById('fb-name').value = '';
    document.getElementById('fb-class').value = '';
    document.getElementById('fb-text').value = '';
    document.querySelectorAll('.star').forEach(s => s.classList.remove('selected'));
    selectedRating = 0;
  }
</script>
