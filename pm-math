    <script>
      function showQuiz(id, btn) {
        document.querySelectorAll('.quiz-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.quiz-sel-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('panel-' + id).classList.add('active');
        btn.classList.add('active');
      }
      function submitQuiz(qid, total) {
        const panel = document.getElementById('panel-' + qid);
        let score = 0, unanswered = 0;
        for (let i = 1; i <= total; i++) {
          const opts = panel.querySelectorAll('input[name="' + qid + '_' + i + '"]');
          let answered = false;
          opts.forEach(opt => {
            const label = opt.closest('.q-opt');
            if (opt.checked) {
              answered = true;
              if (opt.value === '1') { score++; label.classList.add('correct'); }
              else { label.classList.add('wrong'); }
            }
            if (opt.value === '1' && opt.checked === false) {
              // show correct answer only after submit
              label.classList.add('correct');
            }
            opt.disabled = true;
          });
          if (!answered) unanswered++;
        }
        if (unanswered > 0) {
          alert('Please answer all ' + unanswered + ' unanswered question(s) before submitting!');
          // re-enable
          panel.querySelectorAll('input[type=radio]').forEach(r => r.disabled = false);
          panel.querySelectorAll('.q-opt').forEach(l => { l.classList.remove('correct','wrong'); });
          return;
        }
        const pct = Math.round((score / total) * 100);
        let bg, emoji, msg;
        if (pct >= 80) { bg = '#e8f7ed'; emoji = '🎉'; msg = 'Excellent! Keep it up!'; }
        else if (pct >= 60) { bg = '#fff8e6'; emoji = '👍'; msg = 'Good effort! Review the wrong ones.'; }
        else { bg = '#fdecea'; emoji = '📖'; msg = 'Keep practising! You can do it.'; }
        const res = document.getElementById('result-' + qid);
        res.style.background = bg;
        res.innerHTML = '<div style="font-size:2.5rem;">' + emoji + '</div>' +
          '<div class="result-score" style="color:var(--green-700);">' + score + '/' + total + '</div>' +
          '<div class="result-msg">' + msg + '</div>' +
          '<div class="result-detail">You scored ' + pct + '% · Correct: ' + score + ' · Wrong: ' + (total - score) + '</div>';
        res.classList.add('show');
        document.getElementById('retry-' + qid).style.display = 'inline-block';
        panel.querySelector('.quiz-submit').style.display = 'none';
      }
      function retryQuiz(qid) {
        const panel = document.getElementById('panel-' + qid);
        panel.querySelectorAll('input[type=radio]').forEach(r => { r.disabled = false; r.checked = false; });
        panel.querySelectorAll('.q-opt').forEach(l => { l.classList.remove('correct','wrong'); });
        document.getElementById('result-' + qid).classList.remove('show');
        document.getElementById('retry-' + qid).style.display = 'none';
        panel.querySelector('.quiz-submit').style.display = 'block';
      }
    </script>

