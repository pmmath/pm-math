    .subject-card { border: 1px solid var(--border); border-radius: 16px; padding: 2rem; background: var(--off-white); transition: all 0.25s; position: relative; overflow: hidden; }
    .subject-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, var(--green-400), var(--green-300)); transform: scaleX(0); transition: transform 0.3s; transform-origin: left; }
    .subject-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(10,46,26,0.1); border-color: var(--green-300); }
    .subject-card:hover::before { transform: scaleX(1); }
