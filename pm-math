    .subject-card p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; }
    .subject-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 1.25rem; }
    .tag { background: var(--green-50); color: var(--green-700); font-size: 0.75rem; font-weight: 600; padding: 3px 10px; border-radius: 20px; border: 1px solid var(--green-100); }
    #notes { background: var(--off-white); }
    .notes-tabs { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 2rem; margin-bottom: 1rem; }
    .notes-tab { padding: 0.45rem 1rem; border-radius: 20px; font-size: 0.82rem; font-weight: 600; cursor: pointer; border: 1.5px solid var(--border); background: var(--white); color: var(--text-muted); transition: all 0.2s; }
    .notes-tab.active, .notes-tab:hover { background: var(--green-600); color: #fff; border-color: var(--green-600); }
    .notes-subject-tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }
    .notes-subject-tab { padding: 0.4rem 1.2rem; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; border: 1.5px solid var(--border); background: var(--white); color: var(--text-muted); transition: all 0.2s; }
    .notes-subject-tab.active { background: var(--green-700); color: #fff; border-color: var(--green-700); }
    .notes-grid { display: none; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 1rem; }
    .notes-grid.active { display: grid; }
    .note-card { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 1.1rem; display: flex; gap: 0.85rem; align-items: flex-start; transition: all 0.2s; }
    .note-card:hover { box-shadow: 0 8px 24px rgba(10,46,26,0.08); border-color: var(--green-300); }
    .note-icon { width: 38px; height: 38px; border-radius: 9px; background: var(--green-50); border: 1px solid var(--green-100); display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
    .note-title { font-size: 0.85rem; font-weight: 600; color: var(--text-dark); margin-bottom: 2px; line-height: 1.4; }
    .note-meta { font-size: 0.75rem; color: var(--text-muted); }
    .note-badge { display: inline-block; font-size: 0.68rem; font-weight: 600; padding: 2px 7px; border-radius: 4px; margin-top: 5px; }
    .badge-math { background: #e8f7ed; color: #1a6639; }
    .badge-sci { background: #fff8e6; color: #8a5a00; }
    #campus { background: var(--white); }
    .campus-coming-banner { background: linear-gradient(135deg, var(--green-800), var(--green-600)); border-radius: 14px; padding: 2rem; text-align: center; color: #fff; margin-top: 3rem; }
    .campus-coming-banner h3 { font-family: 'Playfair Display', serif; font-size: 1.5rem; margin-bottom: 0.5rem; }
    .campus-coming-banner p { font-size: 0.9rem; color: rgba(255,255,255,0.75); max-width: 480px; margin: 0 auto; line-height: 1.6; }
    .campus-steps { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 1.5rem; }
    .campus-step { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); border-radius: 10px; padding: 0.75rem 1.25rem; font-size: 0.82rem; color: rgba(255,255,255,0.9); }
    .campus-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.2rem; margin-top: 2rem; }
    .campus-placeholder { border-radius: 14px; aspect-ratio: 4/3; background: linear-gradient(135deg, var(--green-50), var(--green-100)); border: 2px dashed var(--green-200); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; text-align: center; padding: 1.5rem; transition: all 0.2s; }
    .campus-placeholder:hover { border-color: var(--green-400); background: var(--green-50); }
    .cs-icon { font-size: 2rem; }
    .cs-title { font-size: 0.85rem; font-weight: 600; color: var(--green-700); }
    .cs-sub { font-size: 0.75rem; color: var(--text-muted); }
    #videos { background: var(--off-white); }
    .videos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; margin-top: 3rem; }
    .video-card { border: 1px solid var(--border); border-radius: 14px; overflow: hidden; background: var(--white); transition: all 0.25s; }
    .video-card:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(10,46,26,0.1); }
    .video-thumb { height: 160px; background: linear-gradient(135deg, var(--green-800), var(--green-600)); display: flex; align-items: center; justify-content: center; position: relative; }
    .play-btn { width: 52px; height: 52px; border-radius: 50%; background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.6); display: flex; align-items: center; justify-content: center; font-size: 1.3rem; cursor: pointer; }
    .video-label { position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.45); color: #fff; font-size: 0.7rem; padding: 3px 8px; border-radius: 4px; }
    .video-info { padding: 1rem 1.25rem; }
    .video-title { font-size: 0.95rem; font-weight: 600; color: var(--text-dark); margin-bottom: 4px; }
    .video-sub { font-size: 0.8rem; color: var(--text-muted); }
    .video-embed-note { font-size: 0.75rem; color: var(--green-500); margin-top: 6px; font-style: italic; }
    #quizzes { background: var(--white); }
    .quiz-list { display: flex; flex-direction: column; gap: 2rem; margin-top: 3rem; }
    .quiz-block { border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .quiz-header { background: linear-gradient(135deg, var(--green-800), var(--green-500)); padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
    .quiz-header-left { display: flex; align-items: center; gap: 12px; }
    .quiz-icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .quiz-title-text { color: #fff; font-weight: 600; font-size: 0.95rem; margin-bottom: 2px; }
    .quiz-meta { color: rgba(255,255,255,0.6); font-size: 0.8rem; }
    .quiz-open-btn { background: var(--gold); color: var(--green-900); font-size: 0.8rem; font-weight: 700; padding: 6px 14px; border-radius: 6px; text-decoration: none; white-space: nowrap; }
    .quiz-open-btn:hover { background: var(--gold-light); }
    .quiz-frame-wrap { width: 100%; background: #fff; }
    .quiz-frame-wrap iframe { display: block; width: 100%; min-width: 100%; height: 640px; border: none; }
    #assignments { background: var(--off-white); }
    .assign-tabs { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 2rem; margin-bottom: 1.5rem; }
    .assign-tab { padding: 0.45rem 1.1rem; border-radius: 20px; font-size: 0.82rem; font-weight: 600; cursor: pointer; border: 1.5px solid var(--border); background: var(--white); color: var(--text-muted); transition: all 0.2s; }
    .assign-tab.active, .assign-tab:hover { background: var(--green-600); color: #fff; border-color: var(--green-600); }
    .assign-list { display: none; flex-direction: column; gap: 1rem; }
    .assign-list.active { display: flex; }
    .assignment-row { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 1.1rem 1.4rem; display: flex; align-items: center; gap: 1.25rem; transition: all 0.2s; }
    .assignment-row:hover { border-color: var(--green-300); box-shadow: 0 4px 16px rgba(10,46,26,0.06); }
    .assign-num { width: 34px; height: 34px; border-radius: 8px; background: var(--green-50); border: 1px solid var(--green-100); display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 700; color: var(--green-600); flex-shrink: 0; }
    .assign-info { flex: 1; }
    .assign-title { font-size: 0.92rem; font-weight: 600; color: var(--text-dark); }
    .assign-sub { font-size: 0.78rem; color: var(--text-muted); margin-top: 2px; }
    .assign-due { font-size: 0.75rem; font-weight: 600; padding: 4px 11px; border-radius: 20px; white-space: nowrap; }
    .due-soon { background: #fff3e0; color: #b35a00; }
    .due-upcoming { background: var(--green-50); color: var(--green-700); }
    .due-open { background: #e3f2fd; color: #1a5276; }
    #resources { background: var(--white); }
    .resources-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; margin-top: 3rem; }
    .resource-card { background: var(--off-white); border: 1px solid var(--border); border-radius: 12px; padding: 1.25rem; text-decoration: none; color: inherit; transition: all 0.2s; display: block; }
    .resource-card:hover { border-color: var(--green-400); background: var(--green-50); transform: translateY(-2px); }
    .resource-icon { font-size: 1.75rem; margin-bottom: 0.75rem; }
    .resource-name { font-size: 0.9rem; font-weight: 600; color: var(--text-dark); margin-bottom: 3px; }
    .resource-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; }
    .resource-arrow { font-size: 0.8rem; color: var(--green-400); margin-top: 8px; font-weight: 600; }
    #nep { background: var(--off-white); }
    .nep-lang-tabs { display: flex; gap: 0.5rem; margin-bottom: 2rem; margin-top: 2rem; }
    .nep-lang-tab { padding: 0.5rem 1.5rem; border-radius: 8px; font-size: 0.88rem; font-weight: 600; cursor: pointer; border: 1.5px solid var(--border); background: var(--white); color: var(--text-muted); transition: all 0.2s; }
    .nep-lang-tab.active { background: var(--green-700); color: #fff; border-color: var(--green-700); }
    .nep-content { display: none; }
    .nep-content.active { display: block; }
    .nep-summary { background: var(--white); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; }
    .nep-summary h3 { font-family: 'Playfair Display', serif; font-size: 1.3rem; color: var(--text-dark); margin-bottom: 1rem; }
